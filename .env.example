# =============================================================================
# AirLock — Environment Configuration
# Copy this file to .env and adjust values for your deployment.
# =============================================================================

# ---------------------------------------------------------------------------
# Upstream API
# ---------------------------------------------------------------------------
# The base URL of the LLM API that AirLock proxies requests to.
# Default: https://api.openai.com
UPSTREAM=https://api.openai.com

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# The port AirLock listens on inside the container / process.
# Default: 8080
PORT=8080

# ---------------------------------------------------------------------------
# Security Pipeline — Layer 2 (Context Sandbox)
# ---------------------------------------------------------------------------
# Enable RAG-aware context sandboxing for indirect injection detection.
# When true, messages containing RAG trigger phrases (e.g. "context:",
# "search results:", "tool output:") will have their external data wrapped
# in <AIRLOCK:UNTRUSTED_EXTERNAL_DATA> security boundaries.
# Default: true
SANDBOX_RAG=true

# Hard-block requests when an indirect injection signal is detected inside
# RAG/tool data. When false, the request is still sandboxed and forwarded,
# but the detection is logged as MEDIUM severity.
# Default: false
BLOCK_INDIRECT=false

# ---------------------------------------------------------------------------
# Fail Mode
# ---------------------------------------------------------------------------
# Controls behavior when the security pipeline encounters an internal error.
# true  = forward the request unchanged (fail open — higher availability)
# false = block the request (fail closed — higher security)
# Default: false
FAIL_OPEN=false
